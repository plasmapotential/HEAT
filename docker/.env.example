# HEAT docker environment. Copy to .env (or run docker/setup.sh, which also
# fills in the machine-specific values) and edit as needed.
#
# Every variable has a fallback default in docker-compose.yml, so an empty or
# missing value here is safe. Precedence: exported shell env > .env > compose
# default (an exported variable wins for one-off overrides, e.g.
#   HEAT_IMAGE_TAG=v4.2.7 ./run.sh gui).

# Image repository and tag. HEAT_IMAGE_TAG is the single source of truth for
# the released tag; scripts/release.sh updates it.
HEAT_IMAGE=plasmapotential/heat
HEAT_IMAGE_TAG=v4.3

# Host port for the Dash GUI (container always serves on 8050).
HEAT_PORT=8050

# Host directory mounted at /root/HEAT (HEAT data/output). Leave empty to use
# the default ~/HEAT. setup.sh writes the resolved absolute path.
HEAT_DATA_DIR=

# Host directory mounted at /root/terminal for batch files. Normally set
# per-invocation by './run.sh tui <batchFile>'; leave empty.
BATCH_DIR=

# Set to 1 to enable the NVIDIA GPU device reservation (requires the nvidia
# container runtime). 0/empty runs without GPU (works on macOS and CI).
HEAT_GPU=0

# Host UID/GID passed into the container as dockerUID/dockerGID; HEAT chowns
# its output to these so files in HEAT_DATA_DIR are owned by you, not root.
# Filled by setup.sh; empty means 0 (root), matching plain 'docker run'.
dockerUID=
dockerGID=
